# Neo4j Configuration
NEO4J_AUTH=neo4j/neo4jpassword
NEO4J_URI=bolt://neo4j:7687

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=neo4flix
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/neo4flix
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgrespassword


# JWT Configuration (CHANGE IN PRODUCTION!)
JWT_SECRET=neo4flix-secret-key-change-in-production-environment
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Application Profiles
SPRING_PROFILES_ACTIVE=docker

# API Gateway
API_GATEWAY_PORT=8080

# Service Ports
FILM_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
RATING_SERVICE_PORT=8003
RECOMMENDATION_SERVICE_PORT=8004
AUTH_SERVICE_PORT=8005

# Frontend
FRONTEND_PORT=4200

